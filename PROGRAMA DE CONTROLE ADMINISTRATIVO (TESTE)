    entry_valor.bind("<Return>", lambda event: confirmar())
    dialog.bind("<Escape>", lambda event: dialog.destroy())

def remover_despesa_variavel():
    """Remove a despesa variável selecionada"""
    global despesas_variaveis
    selecionado = lista_variaveis.curselection()
    if selecionado:
        indice = selecionado[0]
        if mb.askyesno("Confirmar", f"Remover '{despesas_variaveis[indice]['nome']}'?"):
            del despesas_variaveis[indice]
            atualizar_lista_variaveis()

def visualizar_anexo():
    """Abre o anexo da despesa selecionada (se existir)"""
    selecionado = lista_variaveis.curselection()
    if not selecionado:
        mb.showwarning("Aviso", "Selecione uma despesa para visualizar o anexo.")
        return
    indice = selecionado[0]
    anexo = despesas_variaveis[indice].get("anexo")
    if anexo and os.path.exists(anexo):
        try:
            os.startfile(anexo)
        except:
            mb.showerror("Erro", "Não foi possível abrir o arquivo.")
    elif anexo:
        mb.showerror("Erro", f"Arquivo não encontrado:\n{anexo}")
    else:
        mb.showinfo("Sem anexo", "Esta despesa não possui anexo.")

def atualizar_lista_variaveis():
    """Atualiza a Listbox com nome, valor e indicador de anexo"""
    if lista_variaveis:
        lista_variaveis.delete(0, tk.END)
        for i, d in enumerate(despesas_variaveis):
            texto = f"{i+1}. {d['nome']}: R$ {d['valor']:.2f}"
            if d.get("anexo"):
                texto += " 📎"
            lista_variaveis.insert(tk.END, texto)

def registrar_mes():
    """Registra os dados do mês atual (fixos + variáveis + arrecadado)"""
    global registros, despesas_variaveis
    
    # Validações
    try:
        valor_arrecadado = float(entry_arrecadado.get())
        if valor_arrecadado <= 0:
            raise ValueError
    except ValueError:
        mb.showerror("Erro", "Valor arrecadado deve ser um número positivo")
        return

    try:
        luz = float(entry_luz.get())
        agua = float(entry_agua.get())
        jardineiro = float(entry_jardineiro.get())
        salario_sindico = float(entry_salario.get())
        servtec = float(entry_servtec.get())
        zelador = float(entry_zelador.get())
        tim = float(entry_tim.get())
        if any(v < 0 for v in [luz, agua, jardineiro, salario_sindico, servtec, zelador, tim]):
            raise ValueError
    except ValueError:
        mb.showerror("Erro", "Todos os custos fixos devem ser números válidos (>=0)")
        return

    mes_ano = entry_mes_ano.get().strip()
    if not mes_ano:
        mes_ano = datetime.now().strftime("%m/%Y")
        entry_mes_ano.delete(0, tk.END)
        entry_mes_ano.insert(0, mes_ano)
    
    # Verifica se o mês já foi registrado
    for i, registro in enumerate(registros):
        if registro["Mês/Ano"] == mes_ano:
            if not mb.askyesno("Atenção", f"O mês {mes_ano} já foi registrado!\nDeseja substituir?"):
                return
            registros.pop(i)
            break

    total_fixos = luz + agua + jardineiro + salario_sindico + servtec + zelador + tim
    total_variaveis = sum(d["valor"] for d in despesas_variaveis)
    total_despesas = total_fixos + total_variaveis
    saldo = valor_arrecadado - total_despesas

    # Prepara detalhe variáveis com anexos
    detalhe_variaveis = []
    lista_anexos = []
    for d in despesas_variaveis:
        linha = f"{d['nome']}: R$ {d['valor']:.2f}"
        if d.get("anexo"):
            linha += f" [anexo: {os.path.basename(d['anexo'])}]"
            lista_anexos.append(d['anexo'])
        detalhe_variaveis.append(linha)
    detalhe_str = "; ".join(detalhe_variaveis) if detalhe_variaveis else "Nenhuma"

    registro = {
        "Mês/Ano": mes_ano,
        "Arrecadado (R$)": valor_arrecadado,
        "Luz (R$)": luz,
        "Água (R$)": agua,
        "Jardineiro (R$)": jardineiro,
        "Salário Síndico (R$)": salario_sindico,
        "Servtec (R$)": servtec,
        "Zelador (R$)": zelador,
        "Tim (R$)": tim,
        "Total Fixos (R$)": total_fixos,
        "Total Variáveis (R$)": total_variaveis,
        "Total Despesas (R$)": total_despesas,
        "Saldo (R$)": saldo,
        "Detalhe Variáveis": detalhe_str,
        "Anexos": "; ".join(lista_anexos) if lista_anexos else ""
    }

    registros.append(registro)
    salvar_dados()
    atualizar_tabela_historico()

    # Limpa despesas variáveis e campo arrecadado
    despesas_variaveis = []
    atualizar_lista_variaveis()
    entry_arrecadado.delete(0, tk.END)

    mb.showinfo("Sucesso", f"Mês {mes_ano} registrado com sucesso!\n"
                          f"📊 Saldo: R$ {saldo:.2f}\n"
                          f"💰 Arrecadado: R$ {valor_arrecadado:.2f}\n"
                          f"💸 Despesas Totais: R$ {total_despesas:.2f}")

def atualizar_tabela_historico():
    """Atualiza a Treeview com registros ordenados"""
    if tree is None:
        return
    
    # Limpa a tabela
    for row in tree.get_children():
        tree.delete(row)
    
    # Ordena registros por mês/ano
    registros_ordenados = sorted(registros, key=lambda x: x["Mês/Ano"], reverse=False)
    
    # Adiciona os registros na tabela
    for r in registros_ordenados:
        saldo = r["Saldo (R$)"]
        cor = "green" if saldo >= 0 else "red"
        
        item = tree.insert("", tk.END, values=(
            r["Mês/Ano"],
            f"R$ {r['Arrecadado (R$)']:.2f}",
            f"R$ {r['Total Despesas (R$)']:.2f}",
            f"R$ {saldo:.2f}"
        ))
        
        tree.item(item, tags=(cor,))
    
    # Configura as cores
    tree.tag_configure("green", foreground="green")
    tree.tag_configure("red", foreground="red")

def exportar_para_excel():
    """Exporta registros para Excel com hyperlinks"""
    if not registros:
        mb.showwarning("Aviso", "Nenhum registro para exportar.")
        return

    df = pd.DataFrame(registros)
    df = df.sort_values("Mês/Ano")
    df = df.round(2)

    def criar_link(caminho_texto):
        if not caminho_texto or pd.isna(caminho_texto) or caminho_texto == "":
            return "Sem anexo"
        
        primeiro_anexo = caminho_texto.split(";")[0].strip()
        
        if os.path.exists(primeiro_anexo):
            return f'=HYPERLINK("{primeiro_anexo}", "📎 Abrir anexo")'
        else:
            return f"⚠️ Arquivo não encontrado"

    df["Anexo (clique para abrir)"] = df["Anexos"].apply(criar_link)
    
    colunas = ["Mês/Ano", "Arrecadado (R$)", "Luz (R$)", "Água (R$)", 
               "Jardineiro (R$)", "Salário Síndico (R$)", "Servtec (R$)",
               "Zelador (R$)", "Tim (R$)", "Total Fixos (R$)", 
               "Total Variáveis (R$)", "Total Despesas (R$)", "Saldo (R$)",
               "Detalhe Variáveis", "Anexo (clique para abrir)"]
    
    df = df[colunas]

    nome_arquivo = f"relatorio_condominio_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"
    
    try:
        with pd.ExcelWriter(nome_arquivo, engine='openpyxl') as writer:
            df.to_excel(writer, index=False, sheet_name="Registros")
            
            worksheet = writer.sheets["Registros"]
            
            for column in worksheet.columns:
                max_length = 0
                column_letter = column[0].column_letter
                for cell in column:
                    try:
                        if cell.value and isinstance(cell.value, str):
                            if cell.value.startswith("=HYPERLINK"):
                                length = 15
                            else:
                                length = len(str(cell.value))
                        else:
                            length = len(str(cell.value))
                        if length > max_length:
                            max_length = length
                    except:
                        pass
                adjusted_width = min(max_length + 2, 40)
                worksheet.column_dimensions[column_letter].width = adjusted_width
            
            worksheet.freeze_panes = 'A2'
        
        mb.showinfo("Exportado com Sucesso!", 
                   f"✅ Dados exportados para:\n{nome_arquivo}\n\n"
                   f"📎 A pasta com o arquivo será aberta.")
        
        if os.name == 'nt':
            os.startfile(os.path.dirname(os.path.abspath(nome_arquivo)))
    except Exception as e:
        mb.showerror("Erro", f"Erro na exportação:\n{str(e)}")

