    dialog.transient(root)
    dialog.grab_set()
    dialog.configure(bg="#f0f0f0")
    
    # Centralizar
    dialog.update_idletasks()
    x = root.winfo_x() + (root.winfo_width() // 2) - 225
    y = root.winfo_y() + (root.winfo_height() // 2) - 140
    dialog.geometry(f"+{x}+{y}")
    
    # Variáveis
    nome_var = tk.StringVar()
    valor_var = tk.DoubleVar()
    anexo_path = tk.StringVar()
    
    # Nome
    tk.Label(dialog, text="Nome da despesa:", bg="#f0f0f0", font=("Arial", 10)).pack(pady=(10,0))
    entry_nome = tk.Entry(dialog, textvariable=nome_var, width=40, font=("Arial", 10))
