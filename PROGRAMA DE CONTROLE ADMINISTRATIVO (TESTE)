def carregar_dados():
    """Carrega registros do arquivo JSON"""
    global registros
    if os.path.exists(ARQUIVO_DADOS):
        try:
            with open(ARQUIVO_DADOS, 'r', encoding='utf-8') as f:
                data = json.load(f)
                registros = data.get('registros', [])
        except Exception as e:
            print(f"Erro ao carregar dados: {e}")
            registros = []
    else:
        registros = []

def salvar_dados():
    """Salva registros no arquivo JSON"""
    global registros
    try:
        with open(ARQUIVO_DADOS, 'w', encoding='utf-8') as f:
            json.dump({'registros': registros}, f, indent=4, ensure_ascii=False)
    except Exception as e:
        print(f"Erro ao salvar dados: {e}")

def adicionar_despesa_variavel():
    """Janela para adicionar despesa variável (nome, valor e anexo)"""
