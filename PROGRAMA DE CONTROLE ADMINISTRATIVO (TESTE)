def excluir_registro():
    """Exclui o registro selecionado no histórico"""
    selecionado = tree.selection()
    if not selecionado:
        mb.showwarning("Aviso", "Selecione um registro para excluir.")
        return
    
    item = selecionado[0]
    valores = tree.item(item)['values']
    mes_ano = valores[0]
    
    if mb.askyesno("Confirmar Exclusão", f"Tem certeza que deseja excluir o registro de {mes_ano}?"):
        for i, registro in enumerate(registros):
            if registro["Mês/Ano"] == mes_ano:
                registros.pop(i)
                break
        salvar_dados()
        atualizar_tabela_historico()
        mb.showinfo("Excluído", f"Registro de {mes_ano} foi removido.")

