    entry_nome.focus()
    
    # Valor
    tk.Label(dialog, text="Valor (R$):", bg="#f0f0f0", font=("Arial", 10)).pack()
    entry_valor = tk.Entry(dialog, textvariable=valor_var, width=40, font=("Arial", 10))
    entry_valor.pack(pady=5)
    
    # Anexo
    frame_anexo = tk.Frame(dialog, bg="#f0f0f0")
    frame_anexo.pack(pady=10)
    tk.Label(frame_anexo, text="Anexo (boleto/comprovante):", bg="#f0f0f0", font=("Arial", 10)).pack(side=tk.LEFT, padx=5)
    
    def selecionar_anexo():
        caminho = filedialog.askopenfilename(
            title="Selecionar comprovante/boleto",
            filetypes=[("Imagens", "*.png *.jpg *.jpeg *.gif *.bmp"),
                       ("PDF", "*.pdf"),
                       ("Todos os arquivos", "*.*")]
        )
        if caminho:
            anexo_path.set(caminho)
            label_anexo.config(text=f"Anexo: {os.path.basename(caminho)}", fg="#2E7D32")
    
    tk.Button(frame_anexo, text="Selecionar Arquivo", command=selecionar_anexo, bg="#2196F3", fg="white").pack(side=tk.LEFT, padx=5)
    
    label_anexo = tk.Label(dialog, text="Nenhum anexo selecionado", fg="gray", bg="#f0f0f0")
    label_anexo.pack(pady=5)
    
    # Confirmar
    def confirmar():
        nome = nome_var.get().strip()
        if not nome:
            mb.showerror("Erro", "Nome da despesa não pode estar vazio")
            return
        try:
            valor = valor_var.get()
            if valor <= 0:
                raise ValueError
        except:
            mb.showerror("Erro", "Valor deve ser um número positivo")
            return
        anexo = anexo_path.get().strip()
        despesas_variaveis.append({
            "nome": nome,
            "valor": valor,
            "anexo": anexo if anexo else None
        })
        atualizar_lista_variaveis()
        dialog.destroy()
    
    # Botões
    frame_botoes = tk.Frame(dialog, bg="#f0f0f0")
    frame_botoes.pack(pady=15)
    tk.Button(frame_botoes, text="Adicionar", command=confirmar, width=10, bg="#4CAF50", fg="white", font=("Arial", 10, "bold")).pack(side=tk.LEFT, padx=5)
