def verificar_login(janela_login, entry_usuario, entry_senha, tentativas):
    """Verifica as credenciais do usuário"""
    usuario = entry_usuario.get()
    senha = entry_senha.get()
    
    if usuario == USUARIO_CORRETO and senha == SENHA_CORRETA:
        mb.showinfo("✅ Sucesso", "Login realizado com sucesso!")
        janela_login.destroy()
        criar_interface_principal()
    else:
        tentativas[0] += 1
        restantes = MAX_TENTATIVAS - tentativas[0]
        
        if tentativas[0] >= MAX_TENTATIVAS:
            mb.showerror("❌ Acesso Bloqueado", 
                        f"Tentativas excedidas!\nO programa será fechado.")
            janela_login.destroy()
        else:
            mb.showerror("❌ Erro de Login", 
                        f"Usuário ou senha incorretos!\nTentativas restantes: {restantes}")
            entry_senha.delete(0, tk.END)
            entry_senha.focus()

def mostrar_tela_login():
    """Cria a tela de login"""
    tentativas = [0]
    
    janela_login = tk.Tk()
    janela_login.title("Login - Sistema Condomínio")
    janela_login.geometry("400x350")
    janela_login.configure(bg="#f0f0f0")
    
    # Centralizar
    janela_login.update_idletasks()
    largura = 400
    altura = 350
    x = (janela_login.winfo_screenwidth() // 2) - (largura // 2)
    y = (janela_login.winfo_screenheight() // 2) - (altura // 2)
    janela_login.geometry(f"{largura}x{altura}+{x}+{y}")
    
    # Frame superior colorido
    frame_topo = tk.Frame(janela_login, bg="#2E7D32", height=100)
    frame_topo.pack(fill=tk.X)
    
    tk.Label(frame_topo, text="🏢 Condomínio Itamaraty", 
             font=("Arial", 16, "bold"), bg="#2E7D32", fg="white").pack(pady=15)
    
    tk.Label(frame_topo, text="Sistema de Gestão Financeira", 
             font=("Arial", 10), bg="#2E7D32", fg="#e8f5e9").pack()
    
    # Frame principal
    frame_principal = tk.Frame(janela_login, bg="#f5f5f5")
    frame_principal.pack(fill=tk.BOTH, expand=True, padx=30, pady=30)
    
    # Usuário
    tk.Label(frame_principal, text="👤 Usuário:", bg="#f5f5f5", 
             font=("Arial", 11, "bold")).grid(row=0, column=0, sticky=tk.W, pady=10)
    entry_usuario = tk.Entry(frame_principal, width=25, font=("Arial", 11))
    entry_usuario.grid(row=0, column=1, pady=10, padx=10)
    
    # Senha
    tk.Label(frame_principal, text="🔒 Senha:", bg="#f5f5f5", 
             font=("Arial", 11, "bold")).grid(row=1, column=0, sticky=tk.W, pady=10)
    entry_senha = tk.Entry(frame_principal, width=25, font=("Arial", 11), show="•")
    entry_senha.grid(row=1, column=1, pady=10, padx=10)
    
    # Função de login
    def fazer_login():
        verificar_login(janela_login, entry_usuario, entry_senha, tentativas)
    
    # Botão de login
    btn_login = tk.Button(frame_principal, text="🔓 Entrar no Sistema", 
                         command=fazer_login,
                         bg="#4CAF50", fg="white", font=("Arial", 11, "bold"),
                         width=20, height=1, cursor="hand2")
    btn_login.grid(row=2, column=0, columnspan=2, pady=20)
    
    # Informação adicional
    tk.Label(frame_principal, text="Acesso restrito ao síndico", 
             bg="#f5f5f5", font=("Arial", 9), fg="gray").grid(row=3, column=0, columnspan=2)
    
    # Versão
    tk.Label(frame_principal, text="Versão 2.0", 
             bg="#f5f5f5", font=("Arial", 8), fg="gray").grid(row=4, column=0, columnspan=2, pady=10)
    
    # Tecla Enter
    janela_login.bind('<Return>', lambda event: fazer_login())
    
    # Foco inicial
    entry_usuario.focus()
    
    janela_login.mainloop()

